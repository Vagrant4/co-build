# Production database for prisma/schema.postgres.prisma.
# Use a pooled Postgres connection string from Vercel Postgres, Neon, Supabase, or another hosted Postgres provider.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Public site URL used for Stripe success/cancel redirects.
NEXT_PUBLIC_APP_URL="https://your-co-build-domain.com"

# Stripe admin-owned account keys for the recurring S$5/month platform subscription.
STRIPE_SECRET_KEY="sk_live_replace_me"
STRIPE_PLATFORM_SUBSCRIPTION_PRICE_ID="price_replace_me"
