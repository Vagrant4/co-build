{
  "name": "fabrication-space-rental-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:generate:prod": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:push": "prisma db push",
    "db:push:prod": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:deploy:prod": "prisma db push --schema prisma/schema.postgres.prisma --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:if-empty": "tsx prisma/seed-if-empty.ts",
    "vercel-build": "npm run db:deploy:prod && npm run prisma:generate:prod && npm run db:seed:if-empty && next build"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
